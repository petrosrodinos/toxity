// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthRole {
  USER
  ADMIN
  SUPER_ADMIN
  SUPPORT
}

enum DocumentType {
  LOGO
  BANNER
  IMAGE
  VIDEO
  AUDIO
  PDF
  DOCUMENT
  OTHER
}

enum ColorIndicator {
  VERY_SAFE
  SAFE
  MODERATE
  CAUTION
  HIGH_RISK
  UNKNOWN
}

enum SafetyLevel {
  SAFE
  CAUTION
  AVOID
  UNKNOWN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScanMethod {
  BARCODE
  OCR
}

enum ProductImageType {
  HERO
  PACKAGE
  INGREDIENT_LABEL
  FRONT_LABEL
}

enum ProductCreationJobStatus {
  PENDING
  OCR
  ANALYZING
  COMPLETED
  FAILED
}

model User {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  email      String   @unique
  phone      String?  @unique
  password   String
  role       AuthRole
  name       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  password_reset_tokens   PasswordResetToken[]
  product_scans           UserProductScan[]
  product_creation_jobs   ProductCreationJob[]

  @@index([email])
  @@index([phone])
  @@index([uuid])
  @@map("users")
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  user_uuid  String
  token_hash String
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
  @@index([uuid])
  @@map("password_reset_tokens")
}

model Document {
  id         Int          @id @default(autoincrement())
  uuid       String       @unique @default(uuid())
  user_uuid  String
  filename   String
  mimetype   String
  size       Int
  url        String
  path       String
  type       DocumentType @default(LOGO)
  created_at DateTime     @default(now())

  @@index([user_uuid])
  @@index([uuid])
  @@map("documents")
}

model Category {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  name       String   @unique
  slug       String   @unique
  icon_url   String?
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  subcategories Subcategory[]

  @@index([name])
  @@index([uuid])
  @@map("categories")
}

model Subcategory {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique @default(uuid())
  category_uuid String
  name          String
  slug          String
  sort_order    Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  category Category @relation(fields: [category_uuid], references: [uuid], onDelete: Cascade)
  products Product[]

  @@unique([category_uuid, name])
  @@unique([category_uuid, slug])
  @@index([category_uuid])
  @@index([uuid])
  @@map("subcategories")
}

model Brand {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  name        String   @unique
  slug        String   @unique
  logo_url    String?
  website     String?
  country     String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  products Product[]

  @@index([name])
  @@index([uuid])
  @@map("brands")
}

model Ingredient {
  id                         Int             @id @default(autoincrement())
  uuid                       String          @unique @default(uuid())
  name                       String
  name_normalized            String          @unique
  synonyms                   String[]        @default([])
  scientific_name            String?
  description                String?
  ai_summary                 String?
  full_description           String?
  benefits                   String?
  risks                      String?
  safety_explanation         String?
  purpose                    String?
  common_uses                String?
  pregnancy_safety           SafetyLevel?
  child_safety               SafetyLevel?
  allergy_risk               String?
  carcinogenic_evidence      String?
  hormone_disruption_risk    String?
  irritation_risk            String?
  acne_rating                Int?
  comedogenic_rating         Int?
  sensitive_skin_suitability SafetyLevel?
  environmental_impact       String?
  is_vegan                   Boolean?
  is_cruelty_free            Boolean?
  is_biodegradable           Boolean?
  overall_score              Decimal?        @db.Decimal(4, 2)
  safety_score               Decimal?        @db.Decimal(4, 2)
  risk_score                 Decimal?        @db.Decimal(4, 2)
  confidence_score           Decimal?        @db.Decimal(4, 2)
  color_indicator            ColorIndicator  @default(UNKNOWN)
  research_summary           String?
  references                 Json?
  ai_version                 String?
  created_at                 DateTime        @default(now())
  updated_at                 DateTime        @updatedAt

  @@index([name])
  @@index([uuid])
  product_ingredients ProductIngredient[]

  @@index([color_indicator])
  @@map("ingredients")
}

model Product {
  id                        Int                @id @default(autoincrement())
  uuid                      String             @unique @default(uuid())
  barcode                   String?            @unique
  name                      String
  brand_uuid                String
  subcategory_uuid          String
  description               String?
  ai_summary                String?
  benefits                  String?
  risks                     String?
  warnings                  String?
  suitability               String?
  recommended_usage         String?
  storage_info              String?
  pregnancy_safety          SafetyLevel?
  children_safety           SafetyLevel?
  sensitive_skin_safety     SafetyLevel?
  allergy_warnings          String?
  environmental_impact      String?
  is_vegan                  Boolean?
  is_cruelty_free           Boolean?
  overall_score             Decimal            @db.Decimal(4, 2)
  color_indicator           ColorIndicator
  scientific_confidence     Decimal?           @db.Decimal(4, 2)
  marketing_claims          String[]           @default([])
  package_size              String?
  verification_status       VerificationStatus @default(PENDING)
  is_featured               Boolean            @default(false)
  scan_count                Int                @default(0)
  ai_version                String?
  faq                       Json?
  alternative_product_uuids String[]           @default([])
  similar_product_uuids     String[]           @default([])
  created_at                DateTime           @default(now())
  updated_at                DateTime           @updatedAt

  brand               Brand               @relation(fields: [brand_uuid], references: [uuid])
  subcategory         Subcategory         @relation(fields: [subcategory_uuid], references: [uuid])
  product_ingredients ProductIngredient[]
  images              ProductImage[]
  scans               UserProductScan[]

  @@unique([name, brand_uuid])
  @@index([name])
  @@index([uuid])
  @@index([brand_uuid])
  @@index([subcategory_uuid])
  @@index([overall_score(sort: Desc)])
  @@index([created_at(sort: Desc)])
  @@index([scan_count(sort: Desc)])
  @@map("products")
}

model ProductIngredient {
  id              Int    @id @default(autoincrement())
  product_uuid    String
  ingredient_uuid String
  position        Int

  product    Product    @relation(fields: [product_uuid], references: [uuid], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredient_uuid], references: [uuid], onDelete: Cascade)

  @@unique([product_uuid, ingredient_uuid])
  @@unique([product_uuid, position])
  @@index([product_uuid])
  @@index([ingredient_uuid])
  @@map("product_ingredients")
}

model ProductImage {
  id           Int              @id @default(autoincrement())
  uuid         String           @unique @default(uuid())
  product_uuid String
  url          String
  type         ProductImageType
  sort_order   Int              @default(0)

  product Product @relation(fields: [product_uuid], references: [uuid], onDelete: Cascade)

  @@index([product_uuid])
  @@index([uuid])
  @@map("product_images")
}

model UserProductScan {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid())
  user_uuid    String
  product_uuid String
  scanned_at   DateTime   @default(now())
  scan_method  ScanMethod

  user    User    @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)
  product Product @relation(fields: [product_uuid], references: [uuid], onDelete: Cascade)

  @@unique([user_uuid, product_uuid])
  @@index([user_uuid, scanned_at(sort: Desc)])
  @@index([uuid])
  @@map("user_product_scans")
}

model ProductCreationJob {
  id                         Int                      @id @default(autoincrement())
  uuid                       String                   @unique @default(uuid())
  user_uuid                  String
  status                     ProductCreationJobStatus @default(PENDING)
  barcode                    String?
  ingredient_label_image_url String?
  front_label_image_url      String?
  ocr_result                 Json?
  product_uuid               String?
  error_message              String?
  created_at                 DateTime                 @default(now())
  updated_at                 DateTime                 @updatedAt

  user User @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
  @@index([uuid])
  @@index([status])
  @@map("product_creation_jobs")
}
